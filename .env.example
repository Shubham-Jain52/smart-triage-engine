API_V1_STR=/api/v1
PROJECT_NAME=Smart Triage Engine
PROJECT_VERSION=0.1.0
MODEL_PATH=src/data/pretrained_model.pkl
VECTORIZER_PATH=src/data/vectorizer.pkl
CONFIDENCE_THRESHOLD=0.80
HITL_THRESHOLD=0.80
# Comma-separated labels for Hugging Face zero-shot routing (must match your org teams)
CANDIDATE_LABELS=IT Support,DevOps,HR,Security,Hardware
ZS_MODEL_NAME=valhalla/distilbart-mnli-12-1
LOG_LEVEL=INFO
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Inbound POST /api/v1/triage: require X-API-Key header when set (empty = no auth)
WEBHOOK_INGEST_API_KEY=

# Outbound callback after triage (empty = disabled)
TRIAGE_CALLBACK_URL=
TRIAGE_CALLBACK_API_KEY=
TRIAGE_CALLBACK_TIMEOUT_SECONDS=5.0
TRIAGE_CALLBACK_RETRIES=2

# Phase 2 — live RAG (enable after Phase 5 ingest)
RAG_ENABLED=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ticket-routing
PINECONE_NAMESPACE=
# Serverless index hosting (used by scripts/setup_pinecone_index.py)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# all-MiniLM-L6-v2 => 384 dimensions; index dimension must match
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=3
# LLM for Mermaid flowcharts (BYOK — Ollama local or OpenAI-compatible API)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
FLOWCHART_MAX_NODES=15
FLOWCHART_LLM_RETRIES=1

# Phase 5 — ingest source: dummy | csv | jira (use dummy without Jira)
INGEST_SOURCE=dummy
INGEST_CSV_PATH=src/data/historical_tickets.csv

# Phase 5 — Jira cold-start ingest (scripts/ingest.py --source jira)
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
INGEST_MONTHS=12
# Leave empty to auto-build: project = KEY AND status in (Resolved, Done, Closed) AND resolved >= -12m
INGEST_JQL=
INGEST_BATCH_SIZE=100
INGEST_MAX_ISSUES=0

# Phase 3.1 — on-resolve continuous re-ingest (Jira → Pinecone)
INGEST_ON_RESOLVE_ENABLED=false
INGEST_ON_RESOLVE_REQUIRE_RESOLUTION=true
INGEST_ON_RESOLVE_POLL_MINUTES=15
INGEST_ON_RESOLVE_POLL_INTERVAL_SECONDS=300

# Phase 3 — Jira triage worker (issue created → triage → Jira comment)
TRIAGE_API_URL=http://127.0.0.1:8000
TRIAGE_POLL_INTERVAL_SECONDS=2
TRIAGE_POLL_MAX_ATTEMPTS=60
TRIAGE_POLL_TIMEOUT_SECONDS=30
JIRA_TEAM_MAPPING_PATH=integrations/n8n/jira-team-mapping.example.json
JIRA_WORKER_POLL_MINUTES=15
JIRA_WORKER_POLL_INTERVAL_SECONDS=300
JIRA_WORKER_PROCESSED_LABEL=auto-triaged
INCLUDE_TICKET_IDS_IN_COMMENT=false
# Optional: restrict comment visibility to a Jira project role (empty = visible to all)
JIRA_COMMENT_VISIBILITY_ROLE=
