# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Smart Triage Engine
PROJECT_VERSION=0.1.0

# ML Model Configuration
MODEL_PATH=src/data/pretrained_model.pkl
VECTORIZER_PATH=src/data/vectorizer.pkl

# Confidence Threshold for HITL (Human-In-The-Loop)
