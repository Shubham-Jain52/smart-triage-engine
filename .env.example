API_V1_STR=/api/v1
PROJECT_NAME=Smart Triage Engine
PROJECT_VERSION=0.1.0
MODEL_PATH=src/data/pretrained_model.pkl
VECTORIZER_PATH=src/data/vectorizer.pkl
CONFIDENCE_THRESHOLD=0.80
HITL_THRESHOLD=0.80
# Comma-separated labels for Hugging Face zero-shot routing (must match your org teams)
CANDIDATE_LABELS=IT Support,DevOps,HR,Security,Hardware
ZS_MODEL_NAME=valhalla/distilbart-mnli-12-1
LOG_LEVEL=INFO
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Inbound POST /api/v1/triage: require X-API-Key header when set (empty = no auth)
WEBHOOK_INGEST_API_KEY=

# Outbound callback after triage (empty = disabled)
TRIAGE_CALLBACK_URL=
TRIAGE_CALLBACK_API_KEY=
TRIAGE_CALLBACK_TIMEOUT_SECONDS=5.0
TRIAGE_CALLBACK_RETRIES=2
